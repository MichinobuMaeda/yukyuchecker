{
  "name": "yukyuchecker",
  "version": "1.0.0",
  "license": "BSD-3-Clause",
  "author": "Michinobu Maeda",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichinobuMaeda/yukyuchecker.git"
  },
  "scripts": {
    "build:functions": "npm --prefix functions run build",
    "build:ui": "flutter build web --wasm",
    "build": "npm run build:functions && npm run build:ui",
    "dev:ui": "flutter run --dart-define=FLUTTER_ENV=development --web-port 8000",
    "dev": "npm run build:functions && npx firebase emulators:exec --only auth,functions,firestore --ui \"npm run dev:ui\""
  },
  "devDependencies": {
    "firebase-tools": "^15.10.0"
  }
}
