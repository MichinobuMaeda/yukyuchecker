{
  "cSpell.words": [
    "Eventarc",
    "EWNJZNW",
    "firebaseapp",
    "firebasestorage",
    "firestore",
    "fpdart",
    "Maeda",
    "Michinobu",
    "notif",
    "Noto",
    "nvmrc",
    "predeploy",
    "prefs",
    "pubspec",
    "reauthenticating",
    "Reauthentication",
    "riverpod",
    "SDUMRBV",
    "subosito",
    "Yukyu",
    "yukyuchecker"
  ],
  "cSpell.ignorePaths": [
    ".gitignore",
    ".metadata",
    "pubspec.lock",
    "build/*",
    ".dart_tool/*",
    ".idea/*",
    ".vscode/*"
  ],
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "eslint.format.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "directory": "functions",
      "changeProcessCWD": true
    }
  ],
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  }
}