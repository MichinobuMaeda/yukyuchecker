rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/service/admins).data.members;
    }
    match /service/conf {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
